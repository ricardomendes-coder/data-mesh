# ---- App ----
# Generate a strong value:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me
APP_TITLE=Report Hub

# ---- Bootstrap admin (created ONLY on first startup, if no users exist yet) ----
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me-too

# ---- Database (one server + login; the database is chosen per request) ----
# DB_HOST is the server endpoint reachable from this host — e.g. an RDS
# endpoint or private IP when running on an EC2 instance in the same VPC.
DB_HOST=your-db-endpoint
DB_PORT=5432
# DB_NAME: the database preselected in the query dropdown.
DB_NAME=analytics
# DB_CATALOG: database used only to enumerate the others for the dropdown.
DB_CATALOG=postgres
DB_USER=readonly_user
DB_PASSWORD=secret
# Postgres: postgresql+psycopg2  |  MySQL: mysql+pymysql  |  SQL Server: mssql+pyodbc
DB_DRIVER=postgresql+psycopg2
