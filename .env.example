# ---- App ----
# Generate a strong value:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me
APP_TITLE=Report Hub

# ---- Bootstrap admin (created ONLY on first startup, if no users exist yet) ----
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me-too

# ---- SSH tunnel (this container's host reaches the DB over SSH) ----
SSH_HOST=ssh.example.com
SSH_PORT=22
SSH_USER=deploy
SSH_KEY_PATH=/app/secrets/ssh_key
# SSH_KEY_PASSPHRASE=

# ---- Database (address as seen FROM the SSH host) ----
# If the DB runs on the SSH host itself, DB_HOST is usually 127.0.0.1.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mydb
DB_USER=readonly_user
DB_PASSWORD=secret
# Postgres: postgresql+psycopg2  |  MySQL: mysql+pymysql  |  SQL Server: mssql+pyodbc
DB_DRIVER=postgresql+psycopg2
